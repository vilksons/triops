#!/usr/bin/bash

clear && cd "$(dirname "$(realpath "$0")")" || echo

function _@console_@() {
__OS_NOTICE__=0
export __OS_NOTICE__

##################
###  "nul"     ###
###  "linux"   ###
###  "windows" ###
###  "darwin"  ###
##################
__OS__="nul"
export __OS__

__PAWNCC__="nul"
export __PAWNCC__
__DISABLE_NANO__=""
export __DISABLE_NANO__
SAMP_WARGS_STATUS=0
export SAMP_WARGS_STATUS
__SAMP_SERVER=""
export __SAMP_SERVER

save_autoinstall=0
export save_autoinstall

notice_modules=0
export notice_modules
module_loaded=0
export module_loaded

notice_miss_pac=0
export notice_miss_pac

SERVERS_NEXT=0
export SERVERS_NEXT

__cache_save_compile=""
export __cache_save_compile

shell_TITLE=""
export shell_TITLE
shell_DIR="$(dirname "$(realpath "$0")")"
export shell_DIR
shell_NAME="$(basename "$0")"
export shell_NAME
LICENSES="GPL v2.0 or MIT Licenses"
export LICENSES

compiler_MODE="nul"
export compiler_MODE
COMPILER_PAWNCC=""
export COMPILER_PAWNCC
COMPILER_NEXT=0
export COMPILER_NEXT
}

_@console_@

function bash_title() {
    echo -ne "\033]0;$1\007"
}

function collor_yellow() {
# Color Text {Yellow}
# ' echo "$(collor_yellow "label")" content '
COLOR_Y="\e[33m"
    local color="$COLOR_Y"
    local label="$1"
    echo -e "${color}${label}\e[0m"
}
export collor_yellow

function collor_green() {
# Color Text {Green}
# ' echo "$(collor_green "label")" content '
COLOR_G="\e[32m"
    local color="$COLOR_G"
    local label="$1"
    echo -e "${color}${label}\e[0m"
}
export collor_green

function collor_red() {
# Color Text {Red}
# ' echo "$(collor_red "label")" content '
COLOR_R="\e[91m"
    local color="$COLOR_R"
    local label="$1"
    echo -e "${color}${label}\e[0m" 
}
export collor_red

function bash_coltext_a() {
# Color Text {Gray} 
# ' echo "$(bash_coltext_a "label")" content '
COLOR_A="\e[97m"
    local color="$COLOR_A"
    local label="$1"
    echo -e "${color}${label}\e[0m"
}
export bash_coltext_a

function console_TITLE()
{
# Tile Functions
# ' console_TITLE "title" '
    local title=$1
    shell_TITLE="$title"
    bash_title "user:~/ $shell_TITLE"
}
export console_TITLE

: ' compiler option '
COMPILER_AMX_FLAGS=(
    "-A" "-a" "-C+" "-C-" "-c" "-D" "-d0" "-d1" "-d2" "-d3" "-e" "-H" 
    "-i" "-l" "-O" "-p" "-R+" "-R-" "-r" "-S" "-s" "-t" "-v0" "-v1" "-v2"
    "-W" "-X" "-XD" "-Z+" "-Z-" "-E+" "-E-" "-^" "-;+" "-;-" "-(+" "-(-" "sym=" "sym=val"
)
export COMPILER_AMX_FLAGS

ignore_this() {
    "$@" > /dev/null 2>&1
}
export ignore_this

if [ ! -d ".triops" ]; then
    mkdir ".triops"
fi

function load_workspace_module() {
    local module_name=$1
    local module_path="$shell_DIR/$module_name"
    local module_url=$2
    local special_param=$3
    
    if [ -f "$module_path" ] && [ "$module_loaded" != 1 ]; then
        chmod +x "$module_path"
        if [ "$module_name" == ".workspace.py" ]; then
            source <(python3 .workspace.py 2>/dev/null) >/dev/null 2>&1 || echo
        else
            source "$module_path" || sleep 1.0
        fi
        
        clear

        if [ "$special_param" == "compat" ]; then 
            __handleOS ""
        fi
    else
        module_loaded=1
        bash_title "Waiting resources.."

        mkdir -p "$shell_DIR"

        if [ "$special_param" != "ignore" ]; then
            wget -q -O "$module_path" "$module_url" &>/dev/null
        else
            # download in background - efficiency
            wget -q -O "$module_path" "$module_url" &>/dev/null &
        fi

        clear
    fi
}

workspace_module()
{
    # Recheck Sync
    if [ -f ".__update" ]; then
        : ' If there is a problem with creating the ".__updates" file, the module will be automatically reinstalled because the ".triops" folder is deleted. '
        rm .__update
        if [ -d "$shell_DIR/.triops" ]; then
            rm -rf ".triops"
        fi
        sleep 0.10
    fi

    load_workspace_module ".workspace.py" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Scripts/workspace.py" "" 
    load_workspace_module ".triops/security._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Security/security._" "ignore" 
    load_workspace_module ".triops/compat._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Compat/compat._" "compat" 
    load_workspace_module ".triops/compiler._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Compiler/compiler._" "ignore" 
    load_workspace_module ".triops/tligpac._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/TligPac/tligpac._" "ignore" 
    load_workspace_module ".triops/samp._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Package/samp._" "ignore" 
    load_workspace_module ".triops/pawncc._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Package/pawncc._" "ignore" 
    load_workspace_module ".triops/misc._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Misc/misc._" "ignore" 
    load_workspace_module ".triops/server._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Server/server._" "ignore"
}

rest_var() {
    # Reset Variables #

    : ' Checking before unset '
    [ -n "${compiler_MODE+x}" ] && unset compiler_MODE
    [ -n "${COMPILER_PAWNCC+x}" ] && unset COMPILER_PAWNCC
    [ -n "${COMPILER_NEXT+x}" ] && unset COMPILER_NEXT
    [ -n "${SERVERS_NEXT+x}" ] && unset SERVERS_NEXT
    [ -n "${SAMP_WARGS_STATUS+x}" ] && unset SAMP_WARGS_STATUS

    compiler_MODE="nul"
    COMPILER_PAWNCC=""
    COMPILER_NEXT=0
    SERVERS_NEXT=0
    SAMP_WARGS_STATUS=0
    save_autoinstall=0
}

function struct_console_main() {
    #
    #   @mode.Typeof
    #
    
    local _missing_=()
    local _cmds_

    # List of required commands
    for _cmds_ in python3 wget curl grep awk sed tr; do
        command -v "$_cmds_" &>/dev/null || _missing_+=("$_cmds_")
    done

    # If missing packages exist.
    if ((${#_missing_[@]} > 0)); then
        echo " Can't load Workspace Module. Missing packages: ${_missing_[*]}"
        sleep 1.0
        notice_modules=1
    else
        if [ "$notice_modules" != 1 ]; then
            workspace_module ""
            notice_modules=1
        fi
    fi

    #
    #   @Send.Permissions.Typing
    #

    if [ ! -d ".cache" ]; then
        mkdir ".cache"
    fi
    __cache_save_compile=".cache/compiler.log"
    export __cache_save_compile

    if [ "$notice_miss_pac" != 1 ]; then
        if ! command -v jq &> /dev/null; then
            echo -e "$(collor_green "warn:") jq not found."
            sleep 1.0
            clear
        fi
        
        if ! command -v aria2c &> /dev/null; then
            echo -e "$(collor_green "warn:") aria2c not found."
            sleep 1.0
            clear
        fi

        notice_miss_pac=1
    fi

    cd "$shell_DIR" >/dev/null 2>&1 || echo ""

    # find sa-mp server / open.mp server
    OMP_FOUND=$(find . -maxdepth 1 -type f \( -name "omp-server" -o -name "omp-server.exe" \) | head -n 1)
    SAMP_FOUND=$(find . -maxdepth 1 -type f \( -name "samp-server" -o -name "samp-server.exe" \) | head -n 1)

    if [[ -n "$SAMP_FOUND" ]] && [[ -n "$OMP_FOUND" ]]; then
        __SAMP_SERVER="samp"
    elif [[ -n "$SAMP_FOUND" ]]; then
        __SAMP_SERVER="samp"
    elif [[ -n "$OMP_FOUND" ]]; then
        __SAMP_SERVER="omp"
    else
        __SAMP_SERVER="samp"
    fi

if [ ! -f "lang.json" ]; then
    if [ "$__SAMP_SERVER" == "samp" ]; then
    cat > lang.json <<EOF
{
    "amx_flags": [
        "-;+",
        "-(+",
        "-d3"
    ],
    "include_paths": "pawno/include",
    "exclude_paths": [
        "includes",
        "includes2",
        "includes3"
    ],
    "samp_log": "server_log.txt",
    "server_conf": "server.cfg",
    "main_server": "main.pwn",
    "samp_executable": "samp03svr",
    "include_dir": "pawno/include",
    "plugins_dir": "plugins",
    "bot_token": "gsk_abcd",
    "bot_model": "qwen-2.5-32b",
    "bot_profile": "",
    "remcache_auto": "true",
    "repository": "stable"
}
EOF
ignore_this sleep 0.1
chmod +x "$shell_NAME"
exec bash ./"$shell_NAME"
    elif [ "$__SAMP_SERVER" == "omp" ]; then
        cat > lang.json <<EOF
{
    "amx_flags": [
        "-;+",
        "-(+",
        "-d3"
    ],
    "include_paths": "qawno/include",
    "exclude_paths": [
        "includes",
        "includes2",
        "includes3"
    ],
    "samp_log": "log.txt",
    "server_conf": "config.json",
    "main_server": "main.pwn",
    "samp_executable": "omp-server",
    "include_dir": "qawno/include",
    "plugins_dir": "components",
    "bot_token": "gsk_abcd",
    "bot_model": "qwen-2.5-32b",
    "bot_profile": "",
    "remcache_auto": "true",
    "repository": "stable"
}
EOF
ignore_this sleep 0.1
chmod +x "$shell_NAME"
exec bash ./"$shell_NAME"
    fi
fi
    console_TITLE "OPS Mode | Use \`kill\` for refresh."
 
    rest_var ""

    read -e -r -p "user:~$ " ops_table
    mode_TRIOPS "$ops_table"
}
export struct_console_main

mode_TRIOPS() {
    #
    #   @Send.OPS-Mode
    #
    #
    #   always remember to end use 'end_console_main' or 'struct_console_main' so it doesn't crash or exit triops
    #
    
    local trigger_ops="ops"

    case "$ops_table" in
        "compile"*)
            console_TITLE "Compiler"

            if [ -f "$save_LOCK_NAME_SERVER" ]; then
                PID=$(cat "$save_LOCK_NAME_SERVER")
                ignore_this kill -9 "$PID"
                cd "$shell_DIR" >/dev/null 2>&1 || echo "" 
                ignore_this rm "$save_LOCK_NAME_SERVER"
            fi

            local commands_ARGS="${ops_table#compile }"
            local commands_INPUT=""
            local commands_OPAMX=()

            for arg in $commands_ARGS; do
                if [ -z "$commands_INPUT" ]; then
                    commands_INPUT="$arg"
                else
                    commands_OPAMX+=("$arg")
                fi
            done

            local amx_valid=false

            if [[ "$ops_table" == "compile" ]]; then
                compiler_MODE="true"
                triops_compilers ""
            else
                if [[ -n "$commands_INPUT" ]]; then
                    if [[ "$commands_INPUT" == "." ]]; then
                        compiler_MODE="true"
                        triops_compilers ""
                    else
                        if [[ "${#commands_OPAMX[@]}" -eq 0 ]]; then
                            COMPILER_NEXT=1
                        else
                            local amx_valid=true

                            for option in "${commands_OPAMX[@]}"; do
                                # option checking
                                if [[ " ${COMPILER_AMX_FLAGS[*]} " != *" $option "* ]]; then
                                    # not valid
                                    echo -e "$(collor_red "crit:") compiler option \`$option\` not found!"
                                    echo -e "$(collor_yellow "info:") please see: github.com/vilksons/triops/wiki/Compiler-Option"
                                    amx_valid=false
                                    end_console_main ""
                                fi
                            done

                            if $amx_valid; then
                                COMPILER_NEXT=2
                            fi
                        fi
                    fi
                fi

                while IFS= read -r -d '' pawncc; do
                if [ -f "$pawncc" ]; then
                    COMPILER_PAWNCC="$pawncc"
                    break
                fi
                done < <(find "$shell_DIR" -type f -iname "$__PAWNCC__" -print0)

                if [ -z "$COMPILER_PAWNCC" ]; then
                    echo -e "$(collor_red "crit:") $__PAWNCC__ not found!. You can get this in \`pawncc\`"
                    echo
                    read -r -p "install now? [y/n] " INSTALL_NOW

                    while true; do
                        case "$INSTALL_NOW" in
                            [Yy])
                                struct_choice_pawncc ""
                                ;;
                            [Nn])
                                struct_console_main ""
                                ;;
                            *)
                                struct_choice_pawncc ""
                                ;;
                        esac
                    done
                fi

                if ! find "$shell_DIR" -type f -name "$commands_INPUT" | grep -q .; then
                    echo -e "$(collor_red "crit:") $commands_INPUT not found!."
                    struct_console_main ""
                fi

                : '
                    @Map
                '
                while IFS= read -r -d '' __LOOP_COMPILES_FILE; do
                    __files+=("$__LOOP_COMPILES_FILE")
                done < <(find "$shell_DIR" -name "$commands_INPUT" -type f -print0)

                for __LOOP_COMPILES_FILE in "${__files[@]}"; do
                    if [ -f "$__LOOP_COMPILES_FILE" ] && [[ "$__LOOP_COMPILES_FILE" != *.amx ]]; then
                        bash_title "$__LOOP_COMPILES_FILE"

                        local AMX_O
                        AMX_O="$(dirname "$__LOOP_COMPILES_FILE")/$(basename "${__LOOP_COMPILES_FILE%.*}.amx")"

                        echo
                        echo -e "$(collor_green " Compiling: $commands_INPUT")"
                        echo

                        : '
                            @PawnCC.Compile
                        '
                        
                        # allow any subfolder that is inside the gamemodes folder.
                        local __SPECIAL_INCLUDE_DIR
                        __SPECIAL_INCLUDE_DIR=$(find "gamemodes" -type d | tr '\n' ':')
                        __SPECIAL_INCLUDE_DIR=${INCLUDE_DIRS%:}
                    
                        # time milisec checking compiler
                        local start_time
                        start_time=$(date +%s%3N)

                            for _ in {1..10}; do
                                if [ "$COMPILER_NEXT" == 1 ]; then
                                    "$COMPILER_PAWNCC" -i"$json_INCLUDE" "$json_EXCLUDE" -i"$__SPECIAL_INCLUDE_DIR" "$__LOOP_COMPILES_FILE" -o"$AMX_O" "$json_AMX_OPT_F" > "$__cache_save_compile" 2>&1
                                elif [ "$COMPILER_NEXT" == 2 ]; then
                                    "$COMPILER_PAWNCC" -i"$json_INCLUDE" "$json_EXCLUDE" -i"$__SPECIAL_INCLUDE_DIR" "$__LOOP_COMPILES_FILE" -o"$AMX_O" "$json_AMX_OPT_F" "${commands_OPAMX[@]}" > "$__cache_save_compile" 2>&1
                                fi
                            done
                        
                        # end of process
                        local end_time
                        end_time=$(date +%s%3N)

                        local elapsed=$((end_time - start_time))
                        local avg_time=$((elapsed / 10))
                        
                        bash_cache_compiler ""
                        ignore_this sleep 0.1 &&
                        cat "$__cache_save_compile"

                        if [ -s "$AMX_O" ]; then
                            echo
                            echo -e "$(collor_green " Finished: $AMX_O")"

                            if [ "$compiler_MODE" == "true" ]; then
                                shell_TITLE="compilers"
                                bash_title "user:~/ $shell_TITLE"
                            elif [ "$compiler_MODE" == "false" ]; then
                                shell_TITLE="compiler - running"
                                bash_title "user:~/ $shell_TITLE"
                            fi
                            echo
                            echo "total size: $(stat -c%s "$AMX_O") bytes"
                            if [ "$COMPILER_NEXT" == 2 ]; then
                                echo -n "with +option compiler: "
                                echo "${commands_OPAMX[@]}"
                            fi
                            echo "Total execution time: ${elapsed} ms"
                            echo "Average time per iteration: ${avg_time} ms"
                        fi
                    fi
                done
            fi

            end_console_main ""
            ;;
        "running"*)
            console_TITLE "Running"

            if [ -f "$save_LOCK_NAME_SERVER" ]; then
                PID=$(cat "$save_LOCK_NAME_SERVER")
                ignore_this kill -9 "$PID"
                cd "$shell_DIR" >/dev/null 2>&1 || echo "" 
                ignore_this rm "$save_LOCK_NAME_SERVER"
            fi
            
            local commands_ARGS="${ops_table#running }"
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                space_servers ""
            fi

            SERVERS_NEXT=1

            if [ "$commands_INPUT" == "." ]; then
                space_servers ""
            else
                space_wargs_servers "$commands_INPUT"
            fi
            end_console_main ""
            ;;
        "irunn")
            console_TITLE "Compile & Running"

            if [ "$__OS__" == "darwin" ]; then
                ignore_this docker stop $json_EXE_SERV
            elif [ "$__OS__" == "linux" ] || [ "$__OS__" == "windows" ]; then 
                if [ -f "$save_LOCK_NAME_SERVER" ]; then
                    PID=$(cat "$save_LOCK_NAME_SERVER")
                    ignore_this kill -9 "$PID"
                    cd "$shell_DIR" >/dev/null 2>&1 || echo "" 
                    ignore_this rm "$save_LOCK_NAME_SERVER"
                fi
            fi

            compiler_MODE="false"
            triops_compilers ""

            space_servers ""
            ;;
        "debug"*)
            console_TITLE "Debugging"

            if [ "$__OS__" == "darwin" ]; then
                ignore_this docker stop $json_EXE_SERV
            elif [ "$__OS__" == "linux" ] || [ "$__OS__" == "windows" ]; then 
                if [ -f "$save_LOCK_NAME_SERVER" ]; then
                    PID=$(cat "$save_LOCK_NAME_SERVER")
                    ignore_this kill -9 "$PID"
                    cd "$shell_DIR" >/dev/null 2>&1 || echo "" 
                    ignore_this rm "$save_LOCK_NAME_SERVER"
                fi
            fi

            local commands_ARGS="${ops_table#debug }"
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                echo -e "$(bash_coltext_a ":: Enter GM Name:")"
                while true; do
                    read -r -p ">>> " commands_INPUT
                    [[ -n "$commands_INPUT" ]] && break
                done
            fi

            SERVERS_NEXT=2
            
            if [ "$commands_INPUT" == "." ]; then
                space_servers ""
            else
                space_wargs_servers "$commands_INPUT"
            fi
            end_console_main ""
            ;;
        "stop")
            console_TITLE "Stop"

            if [ "$__OS__" == "darwin" ]; then
                ignore_this docker stop $json_EXE_SERV
            elif [ "$__OS__" == "linux" ] || [ "$__OS__" == "windows" ]; then 
                if [ -f "$save_LOCK_NAME_SERVER" ]; then
                    PID=$(cat "$save_LOCK_NAME_SERVER")
                    ignore_this kill -9 "$PID"
                    cd "$shell_DIR" >/dev/null 2>&1 || echo "" 
                    ignore_this rm "$save_LOCK_NAME_SERVER"
                fi
            fi
            end_console_main ""
            ;;
        "restart")
            console_TITLE "Restart"

            if [ "$__OS__" == "darwin" ]; then
                if docker ps --filter "$json_EXE_SERV" | grep -q "$json_EXE_SERV"; then
                    ignore_this docker stop $json_EXE_SERV

                    ignore_this sleep 2
                    space_servers ""
                else
                    echo "error: No progress Server running."
                fi
            elif [ "$__OS__" == "linux" ] || [ "$__OS__" == "windows" ]; then 
                if [ -f "$save_LOCK_NAME_SERVER" ]; then
                    PID=$(cat "$save_LOCK_NAME_SERVER")
                    ignore_this kill -9 "$PID"
                    cd "$shell_DIR" >/dev/null 2>&1 || echo "" 
                    ignore_this rm "$save_LOCK_NAME_SERVER"

                    ignore_this sleep 2
                    space_servers ""
                else
                    echo "error: No progress Server running."
                fi
            fi

            end_console_main ""
            ;;
        "gamemode")
            console_TITLE "Downloads | GameMode"

            struct_choice_samp ""

            end_console_main ""
            ;;
        "pawncc")
            console_TITLE "Downloads | PawnCC"

            struct_choice_pawncc ""

            end_console_main ""
            ;;
        "clear")
            clear; echo -ne "\033[3J"
            struct_console_main ""
            ;;
        "cat"*)
            console_TITLE "Cat"

            local commands_ARGS="${ops_table#cat }"
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                echo -e "$(bash_coltext_a ":: Enter File Name:")"
                while true; do
                    read -r -p ">>> " commands_INPUT
                    [[ -n "$commands_INPUT" ]] && break
                done
            fi

            cat "$commands_INPUT"
            echo
            end_console_main ""
            ;;
        "directory"*)
            console_TITLE "Directory - $shell_DIR"

            local commands_ARGS="${ops_table#directory }"
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                ls -a
                end_console_main ""
            fi

            ignore_this cd "$commands_INPUT" && ls -a && shell_TITLE="directory - $shell_DIR" && bash_title "user:~/ $shell_TITLE" || echo
            struct_console_main ""
            ;;
        "ls")
            ls -a
            struct_console_main ""
            ;;
        "kill")
            console_TITLE "Kill"

            notice_modules=0

            if [ -f "$shell_DIR/lang.json" ]; then
                read -r -p "rebuild \`lang.json\`? [y/n] " REBUILD_LANG

                while true; do
                    case "$REBUILD_LANG" in
                        [Yy])
                            mv lang.json lang.json.old.txt
                            clear
                            ignore_this sleep 0.10
                            chmod +x "$shell_NAME"
                            exec bash ./"$shell_NAME"
                            ;;
                        *)
                            clear
                            ignore_this sleep 0.10
                            chmod +x "$shell_NAME"
                            exec bash ./"$shell_NAME"
                            ;;
                    esac
                done
            fi
            ;;
        "sync" | "syncc")
            if [ "$ops_table" == "sync" ]; then
                console_TITLE "Sync"
            elif [ "$ops_table" == "syncc" ]; then
                console_TITLE "Syncc"
            fi

            local __lat
            __lat=$(curl -s "https://api.github.com/repos/vilksons/triops/commits/main" | grep -o '"sha": "[^"]*' | awk -F': "' '{print $2}')

            local __cur
            __cur=$(cat "$shell_DIR/.commits" 2>/dev/null)

            if [[ "$__lat" == "$__cur" ]]; then
                echo "warning: $shell_NAME is up to date, Nothing to do."
                end_console_main ""
            else
                echo -e "$(bash_coltext_a ":: There is an update!. Commits: (SHA1): ")"
                echo "$__lat"
                
                read -r -n1 -p ":: Do you want to continue Sync Triops? [y/n] " PERMISSION_NEED_S

                echo
                [[ -z "$PERMISSION_NEED_S" ]] && PERMISSION_NEED_S="Y"

                while true; do
                    case "$PERMISSION_NEED_S" in
                        [Yy])
                            if [ -d "$shell_DIR/.triops" ]; then
                                rm -rf ".triops" && sleep 0.1 && mkdir ".triops"
                            fi

                            echo "Updating..."
                            
                            echo "$__lat" > "$shell_DIR/.commits"
                            
                            cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""

                            if [ "$json_WSPACE_REPO" == "stable" ]; then
                                wget -q --show-progress -O "security._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Security/security._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "compat._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Compat/compat._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "tligpac._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/TligPac/tligpac._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "samp._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Package/samp._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "pawncc._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Package/pawncc._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "server._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Server/server._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "misc._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/main/Misc/misc._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "compiler._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Compiler/compiler._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""

                                ignore_this sleep 1 && cd "$shell_DIR" >/dev/null 2>&1 || echo ""

                                if [ "$ops_table" == "syncc" ]; then
                                    wget -q --show-progress -O ".workspace.py" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Scripts/workspace.py"
                                    wget -q --show-progress -O "workspace" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/main/Scripts/workspace"
                                fi
                            elif [ "$json_WSPACE_REPO" == "testing" ]; then
                                wget -q --show-progress -O "security._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Security/security._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "compat._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Compat/compat._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "tligpac._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/TligPac/tligpac._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "samp._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Package/samp._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "pawncc._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Package/pawncc._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "server._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Server/server._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "misc._" "https://raw.githubusercontent.com/vilksons/triops/refs/heads/testing/Misc/misc._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""
                                wget -q --show-progress -O "compiler._" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Compiler/compiler._" || { cd "$shell_DIR" >/dev/null && touch ".__update"; } && cd "$shell_DIR/.triops" >/dev/null 2>&1 || echo ""

                                ignore_this sleep 1 && cd "$shell_DIR" >/dev/null 2>&1 || echo ""

                                if [ "$ops_table" == "syncc" ]; then
                                    wget -q --show-progress -O ".workspace.py" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Scripts/workspace.py"
                                    wget -q --show-progress -O "workspace" "https://raw.githubusercontent.com/vilksons/Triops/refs/heads/testing/Scripts/workspace"
                                fi
                            fi

                            if [ "$ops_table" == "syncc" ]; then
                                if [ -f "lang.json" ]; then
                                    mv lang.json lang.json.old.txt
                                fi
                            fi

                            echo "$__lat" > "$shell_DIR/.commits"

                            cd "$shell_DIR" >/dev/null 2>&1 || echo ""

                            sleep 1 && bash ./workspace
                            ;;
                        *)
                            end_console_main ""
                            break
                            ;;
                    esac
                done
            fi
            ;;
        "checksums"*)
            console_TITLE "Checksums"

            local commands_ARGS="${ops_table#checksums }"

            ignore_this cd "$shell_DIR" || echo ""

            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                echo "sha1:" && sha1sum "$shell_NAME" && echo "sha256:" && sha256sum "$shell_NAME" && echo "md5:" && md5sum "$shell_NAME"
                end_console_main ""
            fi

            for algo in $commands_INPUT; do
                if [[ "$algo" == "sha1" ]]; then
                    echo "sha1:" && sha1sum "$shell_NAME"
                elif [[ "$algo" == "sha256" ]]; then
                    echo "sha256:" && sha256sum "$shell_NAME"
                elif [[ "$algo" == "md5" ]]; then
                    echo "md5:" && md5sum "$shell_NAME"
                else
                    echo "Invalid option: $algo (use sha1, sha256, md5)"
                fi
            done

            end_console_main ""
            ;;
        "exit"*)
            console_TITLE "Exit"

            local commands_ARGS="${ops_table#exit }"

            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                ignore_this sleep 0.100 &&
                bash
            fi
            bash
            ;;
        "chatbot"*)
            console_TITLE "Chatbot"

            local commands_ARGS="${ops_table#chatbot }"

            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                echo -e "$(bash_coltext_a ":: Enter Question Name:")"
                while true; do
                    read -r -p ">>> " commands_INPUT
                    [[ -n "$commands_INPUT" ]] && break
                done
            fi

            if [[ "$commands_ARGS" == "exit" ]]; then
                end_console_main ""
            fi

            _chatbot_response_=$(curl -s -X POST https://api.groq.com/openai/v1/chat/completions \
                -H "Authorization: Bearer $json_CHATBOT_TOKEN" \
                -H "Content-Type: application/json" \
                -d "{
                    \"model\": \"$json_CHATBOT_MODEL\",
                    \"messages\": [
                        {
                        \"role\": \"system\",
                        \"content\": \"$json_CHATBOT_BIODATA\"
                        },
                        {
                        \"role\": \"user\",
                        \"content\": \"$commands_INPUT .. \
                            do not add markdown symbols (.md)\"
                        }
                    ],
                    \"temperature\": 1,
                    \"max_tokens\": 1024,
                    \"top_p\": 1,
                    \"stream\": false,
                    \"stop\": null
                }")
                
__GREEN=$(tput setaf 2)
__RED=$(tput setaf 1)
__ORANGE=$(tput setaf 3)
__RESET=$(tput sgr0)

echo "$_chatbot_response_" | python3 -c "
import sys, json, re
import time

COLORS = {
    'true': '${__GREEN}', 'false': '${__RED}',
    'string': '${__GREEN}', 'int': '${__GREEN}', 'float': '${__GREEN}', 'bool': '${__GREEN}', 
    'double': '${__GREEN}', 'char': '${__GREEN}', 'return': '${__RED}', 'if': '${__GREEN}', 
    'else': '${__GREEN}', 'while': '${__GREEN}', 'for': '${__GREEN}', 'do': '${__GREEN}', 
    'try': '${__ORANGE}', 'catch': '${__ORANGE}', 'finally': '${__ORANGE}', 'throw': '${__RED}', 
    'goto': '${__ORANGE}', 'switch': '${__GREEN}', 'case': '${__GREEN}', 'break': '${__RED}', 
    'continue': '${__RED}', 'class': '${__GREEN}', 'void': '${__GREEN}', 'inline': '${__GREEN}',
    'main': '${__ORANGE}', 'foo': '${__RED}', 'include': '${__GREEN}'
}

def colorize(match):
    word = match.group(0).lower()
    return f'{COLORS.get(word, '')}{word}${__RESET}'

try:
    data = json.loads(sys.stdin.read())
    _chatbot_response_ = data.get('choices', [{}])[0].get('message', {}).get('content')

    if not _chatbot_response_:
        raise ValueError('Error: Response API Failed/not found.')

    _chatbot_response_ = re.sub(r'\b(?:' + '|'.join(COLORS.keys()) + r')\b', colorize, _chatbot_response_, flags=re.IGNORECASE)

    for char in _chatbot_response_:
        print(char, end='', flush=True)
        time.sleep(0.03)

    print()

except json.JSONDecodeError:
    print('Error: Invalid JSON', flush=True)

except ValueError as e:
    print(e, flush=True)

except KeyboardInterrupt:
    print(' Cancelled', end='', flush=True)
    sys.exit(130)
"

            end_console_main ""
            echo
            ;;
        "nano"*)
            if [ "$__DISABLE_NANO__" == "false" ]; then
                if ! command -v nano &> /dev/null; then
                    echo "nano not found!, install first."
                    end_console_main ""
                fi
                
                console_TITLE "GNU/Nano"
                
                local commands_ARGS="${ops_table#nano }"

                if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                    commands_INPUT="$commands_ARGS"
                else
                    echo -e "$(bash_coltext_a ":: Enter File Name:")"
                    while true; do
                        read -r -p ">>> " commands_INPUT
                        [[ -n "$commands_INPUT" ]] && break
                    done
                fi

                nano "$commands_INPUT"
                end_console_main ""
            else
                echo "error: $ops_table: command not found"
                end_console_main ""
            fi
            ;;
        "remcac")
            console_TITLE "Remove Cache"

            if [ "$compiler_MODE" != "nul" ]; then
                # err compiler is running
                echo -e "$(collor_red "crit:") can't remove cache!."
                end_console_main ""
            fi

            if [ ! -f "$shell_DIR/.cache/tligpac" ] && [ ! -f "$shell_DIR/.cache/compiler.log" ]; then
                echo "no cache found."
                end_console_main ""
            fi

            if [ -f "$shell_DIR/.cache/tligpac" ]; then
                echo -e "$(bash_coltext_a ":: Cache Dir: $shell_DIR/.cache/tligpac")"
                read -r -p ":: Do you want to remove ALL files from $shell_DIR/.cache/tligpac? [y/n] " PERMISSION_NEED_RC
                echo
                [[ -z "$PERMISSION_NEED_RC" ]] && PERMISSION_NEED_RC="Y"

                while true; do
                    case "$PERMISSION_NEED_RC" in
                        [Yy])
                            cd "$shell_DIR" || echo "Failed to change directory"
                            rm -rf ".cache/tligpac" && echo "Files removed successfully"
                            sleep 1
                            break
                            ;;
                        *)
                            echo "Operation cancelled"
                            break
                            ;;
                    esac
                done
            fi

            if [ -f "$shell_DIR/.cache/compiler.log" ]; then
                echo -e "$(bash_coltext_a ":: Cache Dir: $shell_DIR/.cache/compiler.log")"
                read -r -p ":: Do you want to remove ALL files from $shell_DIR/.cache/compiler.log? [y/n] " PERMISSION_NEED_RC
                echo
                [[ -z "$PERMISSION_NEED_RC" ]] && PERMISSION_NEED_RC="Y"

                while true; do
                    case "$PERMISSION_NEED_RC" in
                        [Yy])
                            cd "$shell_DIR" || echo "Failed to change directory"
                            rm -rf ".cache/compiler.log" && echo "Files removed successfully"
                            sleep 1
                            end_console_main ""
                            ;;
                        *)
                            echo "Operation cancelled"
                            end_console_main ""
                            ;;
                    esac
                done
            else
                end_console_main ""
            fi
        
            ;;
        "fetch")
            fetch_now ""
            ;;
        "tligpac")
            mode_TLIGPAC ""
            help_dialog_pac ""
            ;;
        "help"* | "$trigger_ops -h"* | "$trigger_ops --h"*)
            local commands_ARGS="${ops_table#"$trigger_ops -h "}"
            local commands_ARGS="${commands_ARGS#help }"
            local commands_ARGS="${commands_ARGS#"$trigger_ops --h "}"

            declare -A descriptions=(
                ["compile"]=":: Compile a project - Usage: compile | (+) [<args>] [target]"
                ["running"]=":: Running a project - Usage: running | (+) [<args>] [target]"
                ["irunn"]=":: Compile & Running a project - Usage: irunn"
                ["debug"]=":: Debug a project - Usage: debug | (+) [<args>] [target]"
                ["stop"]=":: stop all running server progress - Usage: stop"
                ["restart"]=":: Restart all Server - Usage: restart"
                ["gamemode"]=":: Download GameModes SA-MP with Selection - Usage: gamemode"
                ["pawncc"]=":: Download PawnCC SA-MP with Selection - Usage: pawncc"
                ["clear"]=":: Clear Screen Terminal - Usage: clear"
                ["checksums"]=":: Checksums of Triops - Usage: checksums"
                ["cat"]=":: Display a files to Triops Terminal - Usage: cat"
                ["kill"]=":: Kill a Triops Terminal - Usage: kill"
                ["exit"]=":: Exit/End Triops Terminal - Usage: exit | (+) [<args>] \"all\" to kill all tasks"
                ["directory"]=":: Display or Change Terminal Directory - Usage: directory | ls"
                ["update"]=":: Update/Upgrade/Sync Triops Shell up-to-date - Usage: sync"
                ["remcac"]=":: Remove cache \".cache\" Triops - Usage: remcac"
                ["chatbot"]=":: Chatbot Terminal - Usage: chatbot"
                ["nano"]=":: GNU/Nano Editor - Usage: nano"
                ["tligpac"]=":: Triops Mode to TligPac Mode - Usage: tligpac"\
                ["sync"]=":: Sync Normal - Usage: sync"
                ["syncc"]=":: Sync Full - Usage: syncc"
                ["fetch"]=":: Fetch Triops -> Usage: fetch"
            )
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$ops_table" ]]; then
                if [[ -n "${descriptions[$commands_ARGS]}" ]]; then
                    if [[ "$commands_ARGS" == "nano" && "$__DISABLE_NANO__" == "true" ]]; then
                        help_dialog_ops "invalid"
                    else
                        if [ "$commands_ARGS" == "compile" ]; then
                            echo "${descriptions[$commands_ARGS]}"
                            echo " Example: compile bare.pwn +option_amx"
                            echo " For Option. Please See: github.com/vilksons/triops/wiki/Compiler-Option"
                        else
                            echo "${descriptions[$commands_ARGS]}"
                        fi
                    fi
                else
                    help_dialog_ops "invalid"
                fi
            else
                help_dialog_ops ""
            fi

            struct_console_main ""
            ;;
        "$trigger_ops")
            help_dialog_ops ""
            struct_console_main ""
            ;;
        "")
            help_dialog_ops ""
            struct_console_main ""
            ;;
        *)
            not_found_ops ""
            ;;
    esac
}
export mode_TRIOPS

function not_found_ops()
{
    echo "error: $ops_table: command not found"
    help_dialog_ops ""
    struct_console_main ""
}

function help_dialog_ops()
{
    : '
        @Send.Help
    '
    local check_param=$1

    if [ "$check_param" == "invalid" ]; then
        echo "Invalid!.. Please Use:"
    fi

    echo "Usage: ops <command> | help | -h | --h | [<commands>]"
    echo "Commands:"
    echo " compile, running, irunn (compile-run), debug (debugger)"
    echo " stop (stopped server), restart (restart server)"
    echo " gamemode, pawncc, clear (clear-screen)"
    echo " checksums, cat, tligpac, kill, directory"
    echo " sync (update/upgrade), syncc (update/upgrade full)"

    if [ "$__DISABLE_NANO__" == "true" ]; then
        echo " exit, remcac, chatbot, fetch"
    else
        echo " exit, remcac, chatbot, nano, fetch"
    fi
}

function help_dialog_pac()
{
    echo "Usage: ops <command> [<args>]"
    echo "Commands:"
    echo " autoinstall - auto Install from tligpac cache"
    echo " install     - Install/Reinstall Packages"
    echo " remove      - Remove Packages"
    echo " exit        - Exit TligPac Mode"
}

function end_console_main() {
    echo -e "$(collor_yellow "# Press any key to return.")"
    read -r -n 1 -s
    struct_console_main ""
}

: '
    @summary: Main
'
struct_console_main ""
