#!/usr/bin/bash

__handleOS() {
    if [ "$__OS_NOTICE__" != 1 ]; then
        local OS_TYPE
        OS_TYPE=$(uname)

        if [[ "$OS_TYPE" == "Linux" ]] || { [ -d "$HOME/bin" ] && [ -d "$PREFIX" ]; }; then
            cat /etc/os-release &>/dev/null
            __OS__="linux"
            __PAWNCC__="pawncc"
            __OS_NOTICE__=1
            __DISABLE_NANO__="false"
        elif [[ "$OS_TYPE" == "Darwin" ]]; then
            __OS__="darwin"
            __PAWNCC__="pawncc"
            __DISABLE_NANO__="true"
            __OS_NOTICE__=1
        elif [ -d "/c/Windows/System32" ] || [ -d "/mnt/c/Windows/System32" ] || [ -d "/Windows/System32" ]; then
            __OS__="windows"
            __PAWNCC__="pawncc.exe"
            __DISABLE_NANO__="true"
            __OS_NOTICE__=1
        fi

        if { [ "$__OS__" == "windows" ] && [ "$__OS__" == "linux" ]; } || 
           [ "$__OS__" == "darwin" ] || 
           { [ "$__OS__" == "linux" ] && [ "$__OS__" == "darwin" ]; }; then
            
            echo -e "$(bash_coltext_a ":: System detected both Windows and Linux / MacOS (Darwin). Which one will you choose?")"
            read -r -p "Choose OS for Triops Y) Windows, B) GNU/Linux, X) Darwin (Mac): " PERMISSION_NEED_OS

            while true; do
                case "$PERMISSION_NEED_OS" in
                    [Yy]) 
                        __PAWNCC__="pawncc.exe"
                        __DISABLE_NANO__="true"
                        __OS__="windows"
                        __OS_NOTICE__=1
                        break 
                        ;;
                    [Bb]) 
                        __PAWNCC__="pawncc"
                        __DISABLE_NANO__="false"
                        __OS__="linux"
                        __OS_NOTICE__=1
                        break 
                        ;;
                    [Xx]) 
                        __PAWNCC__="pawncc"
                        __DISABLE_NANO__="true"
                        __OS__="darwin"
                        __OS_NOTICE__=1
                        break 
                        ;;
                    *) 
                        echo -e "$(collor_red "err:") Invalid selection. Please enter the correct option!"
                        read -r -p "Choose OS for Triops Y) Windows, B) GNU/Linux, X) Darwin (Mac): " PERMISSION_NEED_OS 
                        ;;
                esac
            done
        fi
    fi
}
